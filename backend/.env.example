# Backend local dev environment template.
# Copy this file to `backend/.env` and fill in real values, then run `npm run dev`.
# The backend's validateEnv() will refuse to start if any of the five REQUIRED
# vars below are missing or empty. See backend/src/config/validateEnv.ts.

# === REQUIRED ===

# JWT signing secret used to sign auth tokens. For local dev, any long random
# string is fine. Never reuse this value in staging or production.
JWT_SECRET=local-dev-only-change-me-to-any-long-random-string

# PostgreSQL connection string. Adjust user/password/host/port/db to match your
# local Postgres setup. The dev database is created automatically by Sequelize
# auto-sync on first startup if it exists and the user has CREATE privileges.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ala_db

# Priority ERP API endpoint and credentials. For local dev without real Priority
# access, leave the placeholders below and set ENABLE_TEST_DATA=true (further
# down) — the backend will boot, but live Priority calls will fail at runtime.
PRIORITY_API_URL=https://priority.example.com/odata/Priority/tabula.ini/test
PRIORITY_API_USERNAME=placeholder
PRIORITY_API_PASSWORD=placeholder

# === OPTIONAL (uncomment to override defaults) ===

# Node environment. Defaults to "development" if unset.
NODE_ENV=development

# Backend HTTP port. Defaults to 5000.
PORT=5000

# Stub Priority responses with canned test data instead of hitting the API.
# Set to "true" for local dev when you don't have real Priority credentials.
ENABLE_TEST_DATA=true

# Skip writing treatment data back to Priority on save. Useful for local dev
# so you don't pollute Priority with test treatments.
SYNC_WITH_PRIORITY=false

# Enable SSL for the Postgres connection. Leave "false" for local dev.
ENABLE_SSL=false
