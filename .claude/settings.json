{
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./frontend/node_modules/.bin/prettier --write \"${FILE_PATH}\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"${FILE_PATH}\" | grep -qE \"backend/src/models/.*\\.ts$\"; then echo \"⚠️ MODEL FILE CHANGED: Remember to create a migration file in backend/src/migrations/ for any new or modified columns.\"; fi'"
          }
        ]
      }
    ]
  }
}
